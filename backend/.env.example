# Puerto en el que corre el backend
PORT=4000

# Entorno: development | production
NODE_ENV=development

# URL del frontend (para CORS y Socket.io)
CLIENT_URL=http://localhost:3000

# Cadena de conexión a PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgresql://postgres:password@localhost:5432/realtime_trello

# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET=change_this_to_a_long_random_secret

# Tiempo de expiración del token
JWT_EXPIRES_IN=7d
